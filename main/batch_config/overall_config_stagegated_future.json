{
    "_comment_usage": "batch_train.py only reads batch_config/overall_config.json. This file is a future template. Copy/rename it to overall_config.json when you want to adopt this shared setup.",

    "max_parallel": 1,
    "batch_size": 256,
    "epochs": 150,
    "learning_rate": 0.001,
    "label_num": 20,
    "dataset_path": "./continue5",
    "results_dir": "results",

    "run_evaluate_after_train": true,
    "debug_eval_subprocess": true,
    "transform_intensity": 0.2,

    "scheduler_patience": 10,
    "scheduler_metric": "val_acc",
    "best_model_metric": "val_acc",

    "classification_loss_type": "competition",

    "detector_competition_loss_weight": 0.0,
    "detector_competition_target_ratio": 50.0,
    "global_energy_concentration_loss_weight": 0.02,
    "global_energy_concentration_target_ratio": 25.0,
    "global_concentration_start_acc": 0.99,

    "score_intensity_source": "global_concentration",
    "score_intensity_cap": 30.0,
    "best_model_acc_weight": 1.0,
    "best_model_intensity_weight": 0.5,

    "aggressive_intensity_optimization": true,
    "aggressive_acc_threshold": 0.99,
    "aggressive_weight_multiplier": 5.0,
    "aggressive_leaky_slope": 0.1,
    "default_leaky_slope": 0.0,

    "use_ddp": false,
    "nproc_per_node": "gpu",
    "master_port": 29500,

    "simulate_misalignment": true,
    "misalignment_translation_max_pixels": 2.0,
    "misalignment_rotation_max_degrees": 0.5,
    "misalignment_tilt_max_degrees": 0.1,

    "in_memory_dataset": true,
    "inherit_best_model": false,
    "inherit_model_path": ""
}
