{
    "max_parallel": 1,
    "batch_size": 256,
    "epochs": 150,
    "learning_rate": 0.001,
    "label_num": 20,
    "run_evaluate_after_train": true,
    "debug_eval_subprocess": true,
    "transform_intensity": 0.2,
    "scheduler_patience": 10,
    "scheduler_metric" : "acc",
    "spatial_mask_loss_weight": 0.02,

    "aggressive_leaky_slope": 0.1,
    
    "auto_spatial_mask_target_ratio": 25.0,
    "best_model_acc_weight": 1.0,
    "best_model_intensity_weight": 0.5,

    "use_ddp": false,
    "nproc_per_node": "gpu",
    "simulate_misalignment": true,
    "misalignment_translation_max_pixels": 2.0,
    "misalignment_rotation_max_degrees": 0.5,
    "misalignment_tilt_max_degrees": 0.1,
    "in_memory_dataset": true,
    "master_port": 29500,
    "dataset_path": "./continue5"

}
